# Chave da API da Anthropic (Claude) — pegue em https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Modelo usado para gerar os fluxos de automação
ANTHROPIC_MODEL=claude-sonnet-4-6

# Banco de dados (SQLite local por padrão)
DATABASE_URL="file:./dev.db"

# E-mail: cada usuário configura o SMTP dele em Configurações (Gmail, Outlook, etc.).
# Resend abaixo é só fallback opcional do admin — usuários não veem isso.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# SMS da plataforma (opcional — usuários NÃO precisam configurar Twilio).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Chave para criptografar credenciais de integração (gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=

# Stripe (opcional). Sem isso, a troca de plano é direta (sem cobrança).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
APP_URL=http://localhost:3000

# Segredo para proteger /api/cron/tick (cron externo envia em x-cron-secret). Opcional em dev.
CRON_SECRET=
# "false" desliga o scheduler in-process (recomendado em produção serverless + cron externo).
ENABLE_INPROCESS_CRON=
